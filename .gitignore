# ============================================================
# 1. Quarto artifacts (HTML/PDF/etc.)
# ============================================================
_site/
_book/
.quarto/
site_libs/
**/libs/
html_test_files/

# Per-document intermediates
*.qmd.json
*.html.json
*.knit.md
*.utf8.md
*_cache/

# Common rendered outputs
*.pdf
*.docx

# Ignore HTML everywhere except rendered output directory
*.html
!_output/html/*.html

# ============================================================
# 2. ETL intermediate data (cache outputs)
# ============================================================
data_intermediate/*
!data_intermediate/.gitkeep

# ============================================================
# 3. R / RStudio artifacts
# ============================================================
.Rhistory
.Rapp.history
.RData
.RDataTmp
.Ruserdata
.Rproj.user/
.Renviron
*.rds

# R CMD build/check outputs
/*.tar.gz
/*.Rcheck/

# Example code in package build process
*-Ex.R

# R Markdown / Bookdown
_bookdown_files/
_book/

# knitr and R markdown default cache directories
*_cache/
/cache/

# produced vignettes
vignettes/*.html
vignettes/*.pdf

# Ignore {targets} pipeline cache
_targets*/

# OAuth2 token
.httr-oauth

# ============================================================
# 4. Python artifacts
# ============================================================
__pycache__/
.ipynb_checkpoints/
.env/
.venv/

# ============================================================
# 5. Editor artifacts
# ============================================================
.vscode/

